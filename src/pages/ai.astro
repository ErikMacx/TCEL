---
// AI-native execution page. Content and section order from the supplied mockup,
// rebuilt in the site's own tokens, fonts and component idioms (no new fonts or
// colours; the mockup's green/Geist system is not used). Page-specific layout
// lives in this file's <style> block, matching the homepage convention.
import Base from '../layouts/Base.astro';
import { CAL_URL } from '../consts';

const GRABS_URL = 'https://grabs.ai';

const title = 'AI-native execution | TCEL | Eric McLean';
const description =
  "Capability is now a commodity. TCEL decides where AI genuinely moves a complex group's numbers, builds the operating system that runs it safely, and hands your people something they own. Strategy first; AI as a tool, not a religion.";
const ogTitle = 'AI-native execution | TCEL | Eric McLean';

// FAQPage schema for the six buyer questions, mirroring the homepage pattern so
// answer engines can lift them directly.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://www.tcel.com/ai#faq',
  mainEntity: [
    { '@type': 'Question', name: 'Is this an AI consultancy or a strategy consultancy?', acceptedAnswer: { '@type': 'Answer', text: 'A strategy consultant who is fluent in AI. We decide together where AI genuinely creates advantage and put it inside a sound strategy, rather than adopt tools in search of a purpose. The strategy comes first, always.' } },
    { '@type': 'Question', name: 'What do I actually own at the end?', acceptedAnswer: { '@type': 'Answer', text: 'The vault, the playbooks, the trained processes and an attested record of what was done. No dependence by design. The capability transfer here is the same one behind the Qatarisation and Omanisation programmes I have led: you leave able to run it yourself.' } },
    { '@type': 'Question', name: 'Who is accountable when an agent gets it wrong?', acceptedAnswer: { '@type': 'Answer', text: 'You are, advised by us. That is exactly why authority is capped in code rather than trusted to discipline, why every action is logged and attributable, and why there is a switch that stops any agent in sixty seconds. Accountability is engineered in, not promised.' } },
    { '@type': 'Question', name: 'Where does AI not belong?', acceptedAnswer: { '@type': 'Answer', text: 'Anywhere the cost of being wrong is high and the work is not yet measurable. We say so plainly. A senior view on where AI is theatre is worth as much as the build itself, and you will get it before any money is spent.' } },
    { '@type': 'Question', name: 'How is delivery priced?', acceptedAnswer: { '@type': 'Answer', text: 'Through GRABS, like staffing: anchored to the day rate of the human interim equivalent, fixed term, outcome-priced. Not per-seat, not a SaaS subscription, no employment overhead.' } },
    { '@type': 'Question', name: 'How fast does this move?', acceptedAnswer: { '@type': 'Answer', text: "Onboarding in days once your knowledge is structured. That structuring is the first paid phase and the floor of every engagement: the worst case you walk away with is your company's brain, organised and yours." } },
  ],
};

const build = [
  ['01', 'The map', 'Every process in the group scored for where AI genuinely pays and where it is theatre. The blueprint everything else is built on.'],
  ['02', 'The connections', 'AI wired into the tools you already run, so it acts inside your systems rather than just chatting beside them.'],
  ['03', 'The knowledge layer', 'Your company brain, structured once and owned by you. The single most valuable thing you buy this quarter, and the floor of every engagement.'],
  ['04', 'The behaviour layer', 'Your SOPs turned into tasks that arrive eighty per cent finished, so the work starts from a draft, not a blank page.'],
  ['05', 'The structure', 'One clean, governed source of truth the whole portfolio reads, instead of twelve private versions drifting apart.'],
  ['06', 'Access with guardrails', 'The whole team using the system, with authority capped in code and a switch that stops any agent in seconds.'],
  ['07', 'The outputs', "Humans own the strategy, the output and every mistake. Agents take the execution off your people's plate. The split never inverts."],
];

const lifecycle = ['Job spec', 'Recruitment', 'Contract', 'Onboarding', 'Line management', '30 / 60 / 90 review', 'Attested handover'];

const faqs = [
  ['Is this an AI consultancy or a strategy consultancy?', 'A strategy consultant who is fluent in AI. We decide together where AI genuinely creates advantage and put it inside a sound strategy, rather than adopt tools in search of a purpose. The strategy comes first, always.'],
  ['What do I actually own at the end?', 'The vault, the playbooks, the trained processes and an attested record of what was done. No dependence by design. The capability transfer here is the same one behind the Qatarisation and Omanisation programmes I have led: you leave able to run it yourself.'],
  ['Who is accountable when an agent gets it wrong?', 'You are, advised by us. That is exactly why authority is capped in code rather than trusted to discipline, why every action is logged and attributable, and why there is a switch that stops any agent in sixty seconds. Accountability is engineered in, not promised.'],
  ['Where does AI not belong?', 'Anywhere the cost of being wrong is high and the work is not yet measurable. We say so plainly. A senior view on where AI is theatre is worth as much as the build itself, and you will get it before any money is spent.'],
  ['How is delivery priced?', 'Through GRABS, like staffing: anchored to the day rate of the human interim equivalent, fixed term, outcome-priced. Not per-seat, not a SaaS subscription, no employment overhead.'],
  ['How fast does this move?', "Onboarding in days once your knowledge is structured. That structuring is the first paid phase and the floor of every engagement: the worst case you walk away with is your company's brain, organised and yours."],
];
---

<Base title={title} description={description} ogTitle={ogTitle} active="ai">
  <meta slot="head" property="og:description" content={description} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <main id="top">
    <!-- HERO -->
    <section class="hero ai-hero">
      <div class="wrap">
        <span class="label eyebrow">AI-native execution · Gulf &amp; EMEA</span>
        <h1>AI made intelligence cheap. The advantage is in what you build around it.</h1>
        <p class="lead">Capability is now a commodity. What stays scarce is a business whose work can be safely handed to AI, chained across teams, and trusted without re-checking by hand. We decide where that pays, build the operating system that runs it, and leave your people able to run it themselves. <b>Strategy first; AI as a tool, not a religion.</b></p>
        <div class="cta-row">
          <a class="btn btn-primary" href={CAL_URL} target="_blank" rel="noopener">Book a conversation</a>
          <a class="btn btn-ghost" href="#operating-system">See what we build</a>
        </div>
        <div class="meta">
          <span><i class="dot"></i>Strategy first</span>
          <span><i class="dot"></i>Built, not bolted on</span>
          <span><i class="dot"></i>Yours at handover</span>
        </div>
      </div>
    </section>

    <!-- SOUND FAMILIAR -->
    <section class="pain-sec">
      <div class="wrap">
        <span class="label">Sound familiar</span>
        <div class="pain-grid reveal">
          <div class="pcell"><span class="pn">01</span><p>You hold licences for four AI tools and no one can tell you what they changed.</p></div>
          <div class="pcell"><span class="pn">02</span><p>Every team runs its own experiments. None of it compounds into anything the group owns.</p></div>
          <div class="pcell"><span class="pn">03</span><p>Someone asks who is accountable when the agent gets it wrong, and the room goes quiet.</p></div>
          <div class="pcell"><span class="pn">04</span><p>The pilots impressed everyone, then quietly stalled. Gartner expects more than 40% of agentic projects to be cancelled.</p></div>
        </div>
      </div>
    </section>

    <!-- THE SHIFT -->
    <section class="shift">
      <div class="wrap shift-grid">
        <div>
          <span class="label">The shift</span>
          <h2>The tool is not the hard part. The environment around it is.</h2>
        </div>
        <div class="shift-body reveal">
          <p>Human minds did not start compounding until they had four things: writing, names, law and money. A memory, an identity, rules, and a settled record of what was done. Three thousand years later, those four are still what turn raw thinking into work a stranger can rely on.</p>
          <p>AI agents are no different. An agent with no memory, no scoped identity, no bounds and no record of its own actions is not autonomous. It is merely unsupervised. The work of an AI strategy is to build the environment that turns cheap capability into work you can safely delegate, measure and trust. The model is the easy part to buy. The operating system around it is the advantage.</p>
        </div>
      </div>
    </section>

    <!-- WHAT WE BUILD -->
    <section id="operating-system" class="build-sec">
      <div class="wrap">
        <div class="sec-head">
          <span class="label">What we build</span>
          <h2>An operating system, not a pile of tools.</h2>
        </div>
        <p class="lead-col">Seven layers, built into the strategy you are already executing. Each one is a client asset, not a slide.</p>
        <div class="build reveal">
          {build.map(([n, h, p]) => (
            <div class="brow">
              <div class="bn">{n}</div>
              <h3>{h}</h3>
              <p>{p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- GOVERNANCE -->
    <section class="gov-sec">
      <div class="wrap">
        <div class="gov reveal">
          <span class="label">Governance</span>
          <h2>Unsupervised is not autonomous.</h2>
          <p>The industry spent three years building brilliant cognition and calling it autonomous while giving it no rules, no bounds and no record. Autonomy means self-government, not the absence of a manager. This is the half of the word the vendors skip, and the half a serious group cannot do without.</p>
          <div class="gov-grid">
            <div class="g"><div class="k">Scoped identity</div><p>Every agent acts under its own identity, never your credentials. What it did is attributable to it, not to a shared login.</p></div>
            <div class="g"><div class="k">Capped in code</div><p>Authority is enforced in code, not by discipline. A kill switch that works in sixty seconds. You are never trapped.</p></div>
            <div class="g"><div class="k">A record you own</div><p>Every action logged and attributable. A live, owned account of what the agents did, which cannot be bought or rushed.</p></div>
            <div class="g"><div class="k">Per-client isolation</div><p>Your data never touches anyone else's. No instance ever reads across a boundary it was not granted.</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- GRABS -->
    <section class="grabs-sec">
      <div class="wrap">
        <div class="grabs reveal">
          <div class="tag">Delivery · a McLean venture</div>
          <h2>Delivered like staff, proven like systems.</h2>
          <p>When the strategy calls for hands on the work, delivery runs through <a class="ilink" href={GRABS_URL} target="_blank" rel="noopener">GRABS</a>, a sister venture. GRABS places interim AI agent teams inside a business the way you hire interim staff: fixed term, managed weekly, measured against a baseline, gone when the job is done. Each team has a job description, a manager, a personnel file and a sixty-second sacking switch. You keep the vault, the playbooks and an attested record of exactly what was done and how well. It is the discipline of interim staffing applied to AI, so the work is accountable every Monday rather than set loose and hoped over.</p>
          <div class="lifecycle">
            {lifecycle.map((step, i) => (
              <>
                <span class={i === lifecycle.length - 1 ? 'step last' : 'step'}>{step}</span>
                {i < lifecycle.length - 1 && <span class="arrow" aria-hidden="true">&rarr;</span>}
              </>
            ))}
          </div>
          <div class="cta-row">
            <a class="btn btn-ghost" href={GRABS_URL} target="_blank" rel="noopener">Visit GRABS</a>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY ME -->
    <section class="why-sec">
      <div class="wrap">
        <div class="sec-head">
          <span class="label">Why me</span>
          <h2>Strategy houses won't build it. Tool vendors have no strategy. We do both.</h2>
        </div>
        <div class="diffs reveal">
          <div class="diff"><div class="x no">Not the strategy houses</div><p>who present a deck about AI and leave you with nothing running to show for it.</p></div>
          <div class="diff"><div class="x no">Not the AI vendors</div><p>who sell a tool with no strategy to put it in, and no one accountable when it is wrong.</p></div>
          <div class="diff"><div class="x no">Not the systems integrator</div><p>for whom this is a year-long programme and a bill long before anything ships.</p></div>
          <div class="diff"><div class="x yes">One senior partner</div><p>who decides where AI actually moves your numbers, builds the operating system that runs it, and hands it to your people. With a product, GRABS, to prove the delivery is real.</p></div>
        </div>
        <p class="closer">The empty middle of three crowded markets, made concrete.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-sec">
      <div class="wrap">
        <div class="sec-head">
          <span class="label">Straight answers</span>
          <h2>Questions buyers ask.</h2>
        </div>
        <div class="faq-list">
          {faqs.map(([q, a]) => (
            <div class="faq reveal"><h3>{q}</h3><p>{a}</p></div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="close">
      <div class="wrap">
        <span class="label">Let's talk</span>
        <h2>Where AI actually moves your numbers, and where it does not.</h2>
        <p>A short, confidential conversation. No deck, no pitch, just a senior view on your situation.</p>
        <a class="btn btn-primary" href={CAL_URL} target="_blank" rel="noopener" style="font-size:1rem;padding:.85rem 1.7rem">Book a conversation</a>
      </div>
    </section>
  </main>
</Base>

<style>
  /* Page-specific layout for /ai. Tokens, fonts and component idioms match the
     homepage; nothing here introduces new colours or fonts. */

  /* shared section rhythm + heads (homepage idiom, page-scoped here) */
  section{padding-block:clamp(3.2rem,7vw,5.6rem)}
  .sec-head{margin-bottom:2.4rem;max-width:64ch}
  .sec-head .label{display:block;margin-bottom:1rem}
  .sec-head h2{font-size:clamp(1.9rem,1.4rem + 1.8vw,3rem);max-width:24ch}
  .lead-col{max-width:62ch;font-size:clamp(1.06rem,1rem + .35vw,1.24rem);color:var(--ink-soft)}

  /* hero */
  .ai-hero{padding-top:clamp(2.4rem,5vw,4rem);padding-bottom:clamp(2.6rem,6vw,4.6rem);border:0}
  .ai-hero .eyebrow{margin-bottom:1.5rem;display:block}
  .ai-hero h1{font-size:clamp(2.2rem,1.2rem + 4vw,4.2rem);max-width:20ch;margin-bottom:1.5rem}
  .ai-hero .lead{font-size:clamp(1.08rem,1.02rem + .4vw,1.28rem);line-height:1.55;max-width:58ch;color:var(--ink-soft)}
  .ai-hero .lead b{font-weight:600;color:var(--ink)}
  .cta-row{display:flex;flex-wrap:wrap;gap:.9rem;margin-top:2.1rem}
  .ai-hero .meta{margin-top:2.2rem;font-family:"IBM Plex Mono",monospace;font-size:.72rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);display:flex;flex-wrap:wrap;gap:.4rem 1.1rem}
  .ai-hero .meta span{display:inline-flex;align-items:center;gap:.5rem}

  /* sound familiar: numbered cards (homepage .pain vocabulary, 4-up grid) */
  .pain-sec .label{display:block;margin-bottom:1.4rem}
  .pain-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-top:2px solid var(--accent);border-radius:3px;overflow:hidden}
  .pcell{background:linear-gradient(180deg,#FFF7F0,#FBE7D8);padding:1.5rem 1.4rem}
  .pcell .pn{font-family:"IBM Plex Mono",monospace;font-size:.7rem;letter-spacing:.12em;color:var(--accent-deep);display:block;margin-bottom:.9rem}
  .pcell p{font-size:1.01rem;line-height:1.45;color:var(--ink-soft)}

  /* the shift: two columns */
  .shift-grid{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);gap:clamp(1.8rem,5vw,4rem);align-items:start}
  .shift h2{font-size:clamp(1.7rem,1.3rem + 1.5vw,2.6rem);max-width:18ch;margin-top:1rem}
  .shift-body p{color:var(--ink-soft);max-width:60ch}
  .shift-body p + p{margin-top:1.1rem}

  /* what we build: numbered rows */
  .build{border-top:2px solid var(--ink);margin-top:2rem}
  .brow{display:grid;grid-template-columns:3rem minmax(0,12ch) minmax(0,1fr);gap:1.2rem;padding:1.3rem .2rem;border-bottom:1px solid var(--line)}
  .brow .bn{font-family:"IBM Plex Mono",monospace;font-size:.78rem;color:var(--accent-deep);padding-top:.3rem}
  .brow h3{font-size:1.2rem;padding-top:.15rem}
  .brow p{font-size:.98rem;color:var(--ink-soft);max-width:60ch}

  /* governance: dark panel (site dark tokens) */
  .gov{background:linear-gradient(180deg,var(--dark),var(--dark-2));color:var(--on-dark);border-radius:4px;padding:clamp(1.8rem,4vw,3rem)}
  .gov .label{color:#CC9C54;display:block;margin-bottom:1rem}
  .gov h2{color:var(--on-dark);max-width:20ch;font-size:clamp(1.7rem,1.3rem + 1.5vw,2.6rem)}
  .gov > p{color:var(--on-dark);max-width:64ch;margin-top:1rem;opacity:.9}
  .gov-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(238,229,212,.16);border:1px solid rgba(238,229,212,.16);border-radius:3px;overflow:hidden;margin-top:2rem}
  .gov-grid .g{background:var(--dark);padding:1.4rem}
  .gov-grid .g .k{font-family:"IBM Plex Mono",monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:#CC9C54;margin-bottom:.7rem}
  .gov-grid .g p{font-size:.95rem;color:var(--on-dark);opacity:.88}

  /* GRABS card */
  .grabs{border:1px solid var(--line);border-top:2px solid var(--accent);border-radius:3px;padding:clamp(1.8rem,4vw,3rem);background:#FFF8F2;box-shadow:0 34px 64px -46px rgba(70,46,12,.4)}
  .grabs .tag{font-family:"IBM Plex Mono",monospace;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent-deep);margin-bottom:1rem}
  .grabs h2{max-width:22ch;font-size:clamp(1.6rem,1.2rem + 1.4vw,2.4rem);margin-bottom:1rem}
  .grabs p{color:var(--ink-soft);max-width:70ch}
  .grabs .ilink{color:var(--accent-deep);text-decoration:underline;text-underline-offset:2px}
  .grabs .ilink:hover{color:var(--ink)}
  .lifecycle{display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin:1.6rem 0 .4rem}
  .lifecycle .step{font-family:"IBM Plex Mono",monospace;font-size:.74rem;color:var(--ink-soft);border:1px solid var(--line);border-radius:20px;padding:.35rem .8rem;background:var(--bg)}
  .lifecycle .step.last{border-color:var(--accent);color:var(--accent-deep)}
  .lifecycle .arrow{color:var(--muted);font-size:.8rem}

  /* why me: diff rows (homepage idiom, light background) */
  .diffs{border-top:1px solid var(--line);margin-top:1rem}
  .diff{display:grid;grid-template-columns:minmax(0,22ch) minmax(0,1fr);gap:1.5rem;padding:1.2rem 0;border-bottom:1px solid var(--line)}
  .diff .x{font-family:"IBM Plex Mono",monospace;font-size:.74rem;letter-spacing:.08em;text-transform:uppercase}
  .diff .x.no{color:var(--muted)}
  .diff .x.yes{color:var(--accent-deep)}
  .diff p{color:var(--ink-soft);max-width:62ch}
  .closer{margin-top:1.8rem;font-family:"Fraunces",Georgia,serif;font-style:italic;font-size:clamp(1.2rem,1rem + .8vw,1.7rem);border-left:3px solid var(--accent);padding-left:1rem;max-width:40ch;color:var(--ink)}

  /* faq: static list (homepage idiom) */
  .faq-list{border-top:1px solid var(--line)}
  .faq{border-bottom:1px solid var(--line);padding:1.7rem 0;display:grid;grid-template-columns:1fr;gap:.6rem}
  .faq h3{font-size:1.2rem}
  .faq p{color:var(--ink-soft);max-width:66ch}

  /* final cta */
  .close{text-align:center;padding-block:clamp(4rem,9vw,6.5rem)}
  .close .label{display:block;margin-bottom:1.2rem}
  .close h2{font-size:clamp(2rem,1.5rem + 2.2vw,3.2rem);max-width:20ch;margin-inline:auto;margin-bottom:1.4rem}
  .close p{color:var(--ink-soft);max-width:46ch;margin-inline:auto;margin-bottom:2.2rem}

  @media(min-width:820px){
    .faq{grid-template-columns:.9fr 1.5fr;gap:2.5rem;align-items:start}
  }
  @media(max-width:820px){
    .shift-grid{grid-template-columns:1fr;gap:1.4rem}
    .pain-grid{grid-template-columns:1fr 1fr}
    .gov-grid{grid-template-columns:1fr}
  }
  @media(max-width:680px){
    .pain-grid{grid-template-columns:1fr}
    .brow{grid-template-columns:1fr;gap:.4rem}
    .brow .bn{padding-top:0}
    .diff{grid-template-columns:1fr;gap:.4rem}
  }
</style>
